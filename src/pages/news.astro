---
import BaseLayout from '../layouts/BaseLayout.astro';

const allNews = [
  // 2026
  {
    year: '2026',
    date: 'May 2026',
    title: 'Starting AI Research Scientist Internship at Samsung Semiconductor',
    description: 'Offer accepted for an AI Research Scientist Intern role at Samsung Semiconductor Inc. in San Jose, CA for Jun 2026 to Sep 2026.',
  },
  {
    year: '2026',
    date: 'Feb 2026',
    title: 'Starting Silicon Solution Engineering Internship at NVIDIA',
    description: 'Offer accepted for a Silicon Solution Engineering Intern role at NVIDIA Corporation in Santa Clara, CA for Mar 2026 to Jun 2026.',
  },
  {
    year: '2026',
    date: 'Jan 2026',
    title: 'Paper accepted at ASPLOS 2026',
    description: '"Mugi: Value Level Parallelism for Efficient LLMs" accepted at ACM ASPLOS 2026. Joint work with D. Price, J.P. Shen, and D. Wu.',
  },
  {
    year: '2026',
    date: 'Jan 2026',
    title: 'Two Workshop Papers accepted at ASPLOS 2026 WUC',
    description: '"Mugi: Value Level Parallelism For Nonlinear Operations in LLMs" and "Agraph: A Unified Graph Representation for At-Will Simulation of Emerging Stacks" accepted at Workshop on Unary Computing (WUC), ASPLOS 2026.',
  },
  {
    year: '2026',
    date: 'Feb 2026',
    title: 'Preprint: NeuroAI Temporal Neural Networks (NeuTNNs)',
    description: '"NeuroAI Temporal Neural Networks (NeuTNNs): Microarchitecture and Design Framework for Specialized Neuromorphic Processing Units" posted to arXiv (arXiv:2602.01546). Proposes NeuTNNs with active dendrites; NeuTNNGen achieves 30–50% synapse count reduction.',
  },
  {
    year: '2026',
    date: 'Feb 2026',
    title: 'Preprint: A-Graph — Unified Graph Representation for Cross-Stack Simulation',
    description: '"A-Graph: A Unified Graph Representation for At-Will Simulation across System Stacks" posted to arXiv (arXiv:2602.04847).',
  },
  {
    year: '2026',
    date: 'Mar 2026',
    title: 'TaxBreak accepted at ISPASS 2026',
    description: '"TaxBreak: Unmasking the Hidden Costs of LLM Inference Through Overhead Decomposition" accepted at IEEE ISPASS 2026 after peer review. The paper is also available on arXiv (arXiv:2603.12465).',
  },
  // 2025
  {
    year: '2025',
    date: 'Jul 2025',
    title: '🏆 Amar Mukherjee Best Paper Award — ISVLSI 2025',
    description: 'Received the Amar Mukherjee Best Paper Award at IEEE ISVLSI 2025 for "Catwalk: Unary Top-K for Efficient Ramp-No-Leak Neuron Design for Temporal Neural Networks." Recognized among 100+ submissions.',
  },
  {
    year: '2025',
    date: 'May 2025',
    title: 'Invited Talk at Jülich Supercomputing Center',
    description: 'Gave an invited talk at the Jülich Supercomputing Center, Jülich, Germany (remote) on "Characterizing and Optimizing LLM Inference Workloads on CPU-GPU Coupled Architectures."',
  },
  {
    year: '2025',
    date: 'May 2025',
    title: 'Paper presented at ISPASS 2025, Ghent, Belgium',
    description: 'Presented "Characterizing and Optimizing LLM Inference Workloads on CPU-GPU Coupled Architectures" at IEEE ISPASS 2025.',
  },
  {
    year: '2025',
    date: 'Apr 2025',
    title: 'Paper presented at DATE 2025, Lyon, France',
    description: 'Presented "Tempus Core: Area-Power Efficient Temporal-Unary Convolution Core for Low-Precision Edge DLAs" at IEEE DATE 2025.',
  },
  {
    year: '2024',
    date: '2024',
    title: 'TNNGen accepted at ISCAS 2024 and invited for TCAS-II publication',
    description: '"TNNGen: Automated Design of Neuromorphic Sensory Processing Units for Time-Series Clustering" was accepted at ISCAS 2024 and invited for publication in TCAS-II: Express Briefs.',
  },
  // 2023
  {
    year: '2023',
    date: 'Oct 2023',
    title: 'Qualcomm Innovation Fellowship — North America Winner',
    description: 'Selected as a 2023 Qualcomm Innovation Fellowship winner.',
  },
];

const years = [...new Set(allNews.map(n => n.year))].sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="News" description="Latest news and updates from Prabhu Vellaisamy.">
  <header class="news-hero page-header">
    <div class="news-hero-copy">
      <p class="hero-kicker">Updates</p>
      <h1>News</h1>
      <p class="subtitle">Announcements, milestones, and publication updates from the research program.</p>
    </div>
    <div class="news-hero-stats">
      <div class="news-stat">
        <div class="news-stat-number">2026</div>
        <div class="news-stat-label">Active year</div>
      </div>
      <div class="news-stat">
        <div class="news-stat-number">2</div>
        <div class="news-stat-label">Internships</div>
      </div>
      <div class="news-stat">
        <div class="news-stat-number">12</div>
        <div class="news-stat-label">Papers</div>
      </div>
    </div>
  </header>

  {years.map(year => (
    <section class="section">
      <h2 class="section-title">{year}</h2>
      <ul class="news-list">
        {allNews.filter(n => n.year === year).map(news => (
          <li class="news-item">
            <span class="news-date">{news.date.replace(/^\w+ /, '')}</span>
            <div class="news-content">
              <div class="news-headline">{news.title}</div>
              <div class="news-body">{news.description}</div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
.news-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.6fr) minmax(260px, 0.8fr);
  gap: var(--space-5);
  align-items: center;
}

.hero-kicker {
  margin: 0 0 var(--space-2);
  color: var(--color-link);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.news-hero h1 {
  margin: 0 0 var(--space-2);
}

.news-hero .subtitle {
  margin: 0;
  color: var(--color-text-light);
  max-width: 78ch;
  line-height: 1.75;
}

.news-hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-2);
}

.news-stat {
  padding: var(--space-3);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  background: linear-gradient(180deg, rgba(255, 253, 250, 0.96) 0%, rgba(248, 240, 231, 0.96) 100%);
  text-align: center;
}

.news-stat-number {
  font-size: 1.45rem;
  font-weight: 800;
  color: var(--color-heading);
  line-height: 1;
}

.news-stat-label {
  margin-top: var(--space-1);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-light);
}

.news-headline {
  font-weight: 600;
  color: var(--color-heading);
  font-size: 0.93rem;
  margin-bottom: var(--space-1);
}

.news-body {
  font-size: 0.86rem;
  color: var(--color-text-light);
  line-height: 1.6;
}

@media (max-width: 760px) {
  .news-hero {
    grid-template-columns: 1fr;
    padding: var(--space-5);
  }

  .news-hero-stats {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 560px) {
  .news-hero-stats {
    grid-template-columns: 1fr;
  }
}
</style>
