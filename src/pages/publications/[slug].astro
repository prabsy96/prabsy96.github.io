---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publications } from '../../data/publications';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return publications.map((publication) => ({
    params: { slug: publication.slug },
    props: { publication },
  }));
}

const { publication } = Astro.props;
const relatedPublications = publications
  .filter(
    (entry) =>
      entry.slug !== publication.slug &&
      (entry.category === publication.category ||
        entry.keywords.some((keyword) => publication.keywords.includes(keyword)))
  )
  .slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: publication.title,
  name: publication.title,
  description: publication.summary,
  author: publication.authors.split(',').map((name: string) => ({
    '@type': 'Person',
    name: name.trim(),
  })),
  datePublished: `${publication.year}-01-01`,
  isPartOf: publication.venue,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  about: publication.keywords,
};
---

<BaseLayout
  title={publication.title}
  description={`${publication.title} by Prabhu Vellaisamy and collaborators. ${publication.summary}`}
  additionalStructuredData={articleSchema}
>
  <article class="paper-page">
    <header class="paper-hero page-header">
      <p class="paper-kicker">{publication.category === 'peer-reviewed' ? 'Peer-reviewed paper' : publication.category === 'workshop' ? 'Workshop paper' : 'Preprint'}</p>
      <h1>{publication.title}</h1>
      <p class="subtitle">{publication.summary}</p>
      <div class="paper-meta">
        <p><strong>Authors:</strong> {publication.authors}</p>
        <p><strong>Venue:</strong> {publication.venue}</p>
        {publication.badge && <p><strong>Note:</strong> {publication.badge}</p>}
      </div>
      <div class="paper-actions">
        <a href={`${base}publications`} class="btn btn-outline">Back to Publications</a>
        {publication.externalUrl && (
          <a href={publication.externalUrl} target="_blank" rel="noopener noreferrer" class="btn">
            {publication.externalLabel ?? 'Open paper'}
          </a>
        )}
      </div>
    </header>

    <section class="section">
      <div class="paper-grid">
        <div class="paper-card">
          <h2 class="section-title">Abstract Summary</h2>
          <p>{publication.summary}</p>
        </div>
        <div class="paper-card">
          <h2 class="section-title">Research Context</h2>
          <p>
            This paper contributes to my research program in {publication.keywords.slice(0, 3).join(', ')}.
            It is part of the broader work on efficient ML systems, hardware-software co-design, and
            deployment-aware computer architecture.
          </p>
          <div class="paper-tags">
            {publication.keywords.map((keyword: string) => <span class="tag">{keyword}</span>)}
          </div>
        </div>
      </div>
    </section>

    {relatedPublications.length > 0 && (
      <section class="section">
        <h2 class="section-title">Related Papers</h2>
        <div class="related-grid">
          {relatedPublications.map((entry: typeof publication) => (
            <a href={`${base}publications/${entry.slug}`} class="related-card">
              <p class="related-title">{entry.title}</p>
              <p class="related-meta">{entry.venue}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .paper-page {
    display: grid;
    gap: var(--space-10);
  }

  .paper-hero {
    display: grid;
    gap: var(--space-4);
  }

  .paper-kicker {
    margin: 0;
    color: var(--color-link);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .paper-meta {
    display: grid;
    gap: var(--space-2);
    color: var(--color-text-light);
  }

  .paper-meta p {
    margin: 0;
  }

  .paper-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .paper-grid,
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .paper-card,
  .related-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    box-shadow: var(--shadow-sm);
  }

  .paper-card p {
    margin: 0;
    line-height: 1.75;
  }

  .paper-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }

  .related-card {
    color: inherit;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
  }

  .related-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .related-title {
    margin: 0 0 var(--space-2);
    color: var(--color-heading);
    font-weight: 600;
  }

  .related-meta {
    margin: 0;
    color: var(--color-text-light);
    font-size: 0.92rem;
  }

  @media (max-width: 760px) {
    .paper-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
