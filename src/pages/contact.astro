---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact" description="Contact information for Prabhu Vellaisamy — CMU ECE PhD candidate.">
  <header class="page-header">
    <h1>Contact</h1>
    <p class="subtitle">Research inquiries, collaborations, and student mentorship</p>
  </header>

  <section class="section">
    <p>
      I'm always happy to hear from fellow researchers, students, and anyone interested
      in my work on LLM inference, hardware accelerators, or neuromorphic computing.
      Feel free to reach out through any of the channels below.
    </p>

    <div class="contact-info">
      <div class="contact-item">
        <h3>Email</h3>
        <p>
          <a href="mailto:pvellais@andrew.cmu.edu">pvellais@andrew.cmu.edu</a>
        </p>
        <p class="contact-note">Preferred channel for research inquiries and collaborations.</p>
      </div>

      <div class="contact-item">
        <h3>Affiliation</h3>
        <p>
          Carnegie Mellon University<br>
          Department of Electrical and Computer Engineering<br>
          Pittsburgh, PA 15213
        </p>
      </div>

      <div class="contact-item">
        <h3>Online Profiles</h3>
        <ul class="profile-links">
          <li><a href="https://github.com/prabsy96" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="https://scholar.google.com/citations?user=ePfYSNsAAAAJ" target="_blank" rel="noopener noreferrer">Google Scholar</a></li>
          <li><a href="https://linkedin.com/in/pvellais" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
        </ul>
      </div>

      <div class="contact-item">
        <h3>CV</h3>
        <p>
          <a href={`${base}resume.pdf`}>Download CV (PDF)</a>
        </p>
        <p class="contact-note">Updated March 2026.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">For Students</h2>
    <p>
      If you're a student interested in research opportunities in unary computing, deep learning
      architectures, or LLM inference optimization, please include the following in your email:
    </p>
    <ul>
      <li>Your CV or resume</li>
      <li>A brief description of your research interests</li>
      <li>Any relevant coursework or projects (especially in computer architecture or ML)</li>
      <li>What you hope to gain from the experience</li>
    </ul>
  </section>

  <section class="section">
    <h2 class="section-title">Response Time</h2>
    <p>
      I try to respond to all emails within a week. If you haven't heard back,
      feel free to send a follow-up. For urgent matters, please mention it in
      your subject line.
    </p>
  </section>
</BaseLayout>

<style>
  .contact-info {
    display: grid;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
  }

  .contact-item h3 {
    margin-top: 0;
    margin-bottom: var(--spacing-sm);
    font-size: 1.1rem;
  }

  .contact-item p {
    margin: 0 0 var(--spacing-xs) 0;
  }

  .contact-note {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .profile-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .profile-links li {
    margin: 0;
  }

  @media (min-width: 600px) {
    .contact-info {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
