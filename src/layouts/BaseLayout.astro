---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/layout.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'Personal research website of Prabhu Vellaisamy', wide = true } = Astro.props;
const fullTitle = title === 'Home' ? 'Prabhu Vellaisamy' : `${title} | Prabhu Vellaisamy`;
const base = import.meta.env.BASE_URL;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const pageDescription = description;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Prabhu Vellaisamy',
      url: Astro.site?.toString(),
      email: 'pvellais@andrew.cmu.edu',
      affiliation: {
        '@type': 'CollegeOrUniversity',
        name: 'Carnegie Mellon University',
      },
      sameAs: [
        'https://github.com/prabsy96',
        'https://scholar.google.com/citations?user=ePfYSNsAAAAJ',
        'https://linkedin.com/in/pvellais',
      ],
      jobTitle: 'PhD Candidate in Electrical and Computer Engineering',
    },
    {
      '@type': 'WebSite',
      name: 'Prabhu Vellaisamy',
      url: Astro.site?.toString(),
      description: pageDescription,
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Prabhu Vellaisamy" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{fullTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline>
          {`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '${gaMeasurementId}', { anonymize_ip: true });
          `}
        </script>
      </>
    )}
  </head>
  <body>
    <Navbar />
    <main class:list={['container', { 'container-wide': wide }]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - 200px);
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
  }
</style>
